    "nuxt-ssr-api-logger": "2.0.2",
    "nuxt-typed-router": "4.0.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.8.2",
    "socket.io-client": "^4.8.3",
