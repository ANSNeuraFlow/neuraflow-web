{
  "name": "neuraflow-web",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3000",
    "dev:network": "nuxt dev --port 3000 --host 0.0.0.0 --qr",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare:nuxt": "nuxt prepare",
    "postinstall": "nuxt prepare",
    "preinstall": "npx only-allow pnpm",
    "typecheck": "nuxt typecheck",
    "prepare": "husky",
    "start": "node .output/server/index.mjs",
    "lint:eslint": "eslint --ext .js,.ts,.vue .",
    "lint:eslint:fix": "pnpm lint:eslint --fix",
    "lint:stylelint": "stylelint '**/*.{vue,css}'",
    "lint:stylelint:fix": "pnpm lint:stylelint --fix",
    "lint:prettier": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint && pnpm lint:prettier",
    "lint:fix": "pnpm lint:eslint:fix && pnpm lint:stylelint:fix && pnpm lint:prettier:fix"
  },
  "dependencies": {
