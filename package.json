    "lint-staged": "^16.2.7",
    "prettier-plugin-sort-json": "4.1.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "ts-toolbelt": "^9.6.0",
    "typescript": "^5.9.3",
