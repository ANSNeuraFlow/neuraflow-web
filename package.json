    "@nuxtjs/google-fonts": "3.2.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@vee-validate/nuxt": "^4.15.1",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
